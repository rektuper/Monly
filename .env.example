# =============================================================================
# Корневой .env — только для Docker Compose (docker compose up)
# Скопируйте:  cp .env.example .env   (Windows: copy .env.example .env)
# =============================================================================

# --- Обязательно (без этих значений compose не запустится) -------------------

# Пароль пользователя PostgreSQL внутри контейнера db
DB_PASSWORD=change_me_strong_password

# Секрет для подписи JWT-токенов (длинная случайная строка, минимум 32 символа)
SECRET_KEY=change_me_long_random_string

# --- База данных (можно оставить по умолчанию) --------------------------------

DB_USER=budget_user
DB_NAME=smart_budget

# --- URL фронтенда (для CORS и ссылок в письмах) ------------------------------

# Адрес, с которого открываете приложение в браузере (через запятую, если несколько)
ALLOWED_ORIGINS=http://localhost:3001

# Базовый URL фронтенда — попадает в ссылки сброса пароля и приглашений в семью
FRONTEND_URL=http://localhost:3001

# --- JWT (можно оставить по умолчанию) --------------------------------------

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Почта SMTP (нужна для регистрации, смены и сброса пароля) --------------

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=МОНЛИ
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --- Опционально --------------------------------------------------------------

VERIFICATION_CODE_EXPIRE_MINUTES=15
PASSWORD_RESET_EXPIRE_MINUTES=60
ENABLE_ML_CATEGORIZATION=true
