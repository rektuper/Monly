# =============================================================================
# backend/.env — для локального запуска бэкенда (без Docker)
# Скопируйте:  cp .env.example .env   (Windows: copy .env.example .env)
# Запуск:       uvicorn main:app --reload --host 0.0.0.0 --port 8000
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------

# Хост БД: 127.0.0.1 при локальном PostgreSQL, db — только внутри Docker
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=smart_budget
DB_USER=budget_user
DB_PASSWORD=change_me_strong_password

# --- JWT (обязательно смените SECRET_KEY) -------------------------------------

SECRET_KEY=change_me_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS ---------------------------------------------------------------------

# URL фронтенда Vite через запятую (по умолчанию порт 5173)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Ссылки в письмах и приглашениях ------------------------------------------

# Должен совпадать с адресом, на котором открыт фронтенд
FRONTEND_URL=http://localhost:5173

# --- Почта SMTP (нужна для регистрации, смены и сброса пароля) --------------

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=МОНЛИ
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# --- Опционально --------------------------------------------------------------

VERIFICATION_CODE_EXPIRE_MINUTES=15
PASSWORD_RESET_EXPIRE_MINUTES=60
ENABLE_ML_CATEGORIZATION=true
