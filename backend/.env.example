# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=smart_budget
DB_USER=budget_user
DB_PASSWORD=change_me_strong_password

# JWT
SECRET_KEY=change_me_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — URL фронтенда через запятую
ALLOWED_ORIGINS=https://your-domain.ru,http://your-domain.ru

# Ссылки приглашения в семью
FRONTEND_URL=http://localhost:5173

# Почта поддержки (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=МОНЛИ
SMTP_USE_TLS=true
SMTP_USE_SSL=false
VERIFICATION_CODE_EXPIRE_MINUTES=15
