# =============================================================================
# frontend/.env — для локального запуска фронтенда (npm run dev)
# Скопируйте:  cp .env.example .env   (Windows: copy .env.example .env)
# Запуск:       npm run dev  →  http://localhost:5173
#
# При запуске через Docker этот файл не нужен: API URL задаётся при сборке образа.
# =============================================================================

# Базовый URL API (без завершающего слэша)
# Локально — напрямую на uvicorn:
VITE_API_URL=http://127.0.0.1:8000

# URL для аватаров и /uploads (опционально).
# Если не задан — выводится из VITE_API_URL автоматически.
# VITE_MEDIA_URL=http://127.0.0.1:8000

# --- Продакшен (если фронтенд и API на одном домене за Nginx) -----------------
# VITE_API_URL=https://your-domain.ru/api
# VITE_MEDIA_URL=https://your-domain.ru
